<?xml version="1.0" encoding="UTF-8"?>
<!-- 
  Example KPMR Risk Profile Tree
  This file demonstrates the structure defined in kpmr_risk_profile_tree.xsd
  
  To validate: xmllint - -schema schema/kpmr_risk_profile_tree.xsd example_risk_profile_tree.xml - -noout
-->
<RiskProfileTree>
  
  <!-- Example 1: Operational Risk with nested hierarchy -->
  <RiskProfileNode>
    <Profile_ID>RI0400000000</Profile_ID>
    <risiko_name>Risiko Operasional</risiko_name>
    
    <!-- Level 1: Process and Business Category -->
    <RiskProfileNode>
      <Profile_ID>RI0400100000</Profile_ID>
      <risiko_name>Risiko Operasional</risiko_name>
      <Faktor_Penilaian>1. Kompleksitas Proses dan Produk</Faktor_Penilaian>
      
      <!-- Level 2: Specific Factors -->
      <RiskProfileNode>
        <Profile_ID>RI0400100100</Profile_ID>
        <risiko_name>Risiko Operasional</risiko_name>
        <Faktor_Penilaian>1.1 Skala usaha dan struktur organisasi
(Total jumlah kantor LJK)</Faktor_Penilaian>
      </RiskProfileNode>
      
      <RiskProfileNode>
        <Profile_ID>RI0400100200</Profile_ID>
        <risiko_name>Risiko Operasional</risiko_name>
        <Faktor_Penilaian>1.2 Kompleksitas proses bisnis dan keragaman produk/jasa
(Jumlah produk / aktivitas baru yang diluncurkan selama periode penilaian)</Faktor_Penilaian>
      </RiskProfileNode>
    </RiskProfileNode>
    
    <!-- Level 1: Human Resources Category -->
    <RiskProfileNode>
      <Profile_ID>RI0400200000</Profile_ID>
      <risiko_name>Risiko Operasional</risiko_name>
      <Faktor_Penilaian>2. Sumber Daya Manusia (SDM)</Faktor_Penilaian>
      
      <!-- Level 2: HR Management -->
      <RiskProfileNode>
        <Profile_ID>RI0400200100</Profile_ID>
        <risiko_name>Risiko Operasional</risiko_name>
        <Faktor_Penilaian>2.1 Penerapan manajemen SDM</Faktor_Penilaian>
        
        <!-- Level 3: Specific Metrics -->
        <RiskProfileNode>
          <Profile_ID>RI0400200101</Profile_ID>
          <risiko_name>Risiko Operasional</risiko_name>
          <Faktor_Penilaian>2.1.1 Realisasi Biaya Training
(Persentase rata-rata realisasi Biaya Training terhadap Biaya Tenaga Kerja)</Faktor_Penilaian>
        </RiskProfileNode>
        
        <RiskProfileNode>
          <Profile_ID>RI0400200102</Profile_ID>
          <risiko_name>Risiko Operasional</risiko_name>
          <Faktor_Penilaian>2.1.2 Turn Over Karyawan (Regretted)
(Persentasi turnover karyawan [regretted])</Faktor_Penilaian>
        </RiskProfileNode>
      </RiskProfileNode>
    </RiskProfileNode>
  </RiskProfileNode>
  
  <!-- Example 2: Credit Risk -->
  <RiskProfileNode>
    <Profile_ID>RI0100000000</Profile_ID>
    <risiko_name>Risiko Kredit</risiko_name>
    
    <RiskProfileNode>
      <Profile_ID>RI0100100000</Profile_ID>
      <risiko_name>Risiko Kredit</risiko_name>
      <Faktor_Penilaian>1. Kualitas Aset</Faktor_Penilaian>
      
      <RiskProfileNode>
        <Profile_ID>RI0100100100</Profile_ID>
        <risiko_name>Risiko Kredit</risiko_name>
        <Faktor_Penilaian>1.1 Non Performing Loan (NPL) Ratio
(Rasio kredit bermasalah terhadap total kredit)</Faktor_Penilaian>
      </RiskProfileNode>
    </RiskProfileNode>
  </RiskProfileNode>
  
  <!-- Example 3: Market Risk (simple structure) -->
  <RiskProfileNode>
    <Profile_ID>RI0200000000</Profile_ID>
    <risiko_name>Risiko Pasar</risiko_name>
    
    <RiskProfileNode>
      <Profile_ID>RI0200100000</Profile_ID>
      <risiko_name>Risiko Pasar</risiko_name>
      <Faktor_Penilaian>1. Eksposur Risiko Pasar
(Nilai eksposur trading book terhadap modal)</Faktor_Penilaian>
    </RiskProfileNode>
  </RiskProfileNode>
  
  <!-- Example 4: Strategic Risk -->
  <RiskProfileNode>
    <Profile_ID>RI0700000000</Profile_ID>
    <risiko_name>Risiko Stratejik</risiko_name>
    
    <RiskProfileNode>
      <Profile_ID>RI0700100000</Profile_ID>
      <risiko_name>Risiko Stratejik</risiko_name>
      <Faktor_Penilaian>1. Faktor Internal dan Eksternal</Faktor_Penilaian>
      
      <RiskProfileNode>
        <Profile_ID>RI0700100100</Profile_ID>
        <risiko_name>Risiko Stratejik</risiko_name>
        <Faktor_Penilaian>1.1 Visi, misi, dan arah bisnis yang ingin dicapai oleh LJK</Faktor_Penilaian>
      </RiskProfileNode>
      
      <RiskProfileNode>
        <Profile_ID>RI0700100200</Profile_ID>
        <risiko_name>Risiko Stratejik</risiko_name>
        <Faktor_Penilaian>1.2 Kondisi eksternal seperti perubahan regulasi dan persaingan</Faktor_Penilaian>
      </RiskProfileNode>
    </RiskProfileNode>
  </RiskProfileNode>
  
</RiskProfileTree>
